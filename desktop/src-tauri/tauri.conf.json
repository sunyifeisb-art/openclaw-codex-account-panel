{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Panel",
  "version": "0.1.4",
  "identifier": "ai.openclaw.codexpanel",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "resources": {
      "../../codex-account-panel/auth-store-sync.mjs": "panel/auth-store-sync.mjs",
      "../../codex-account-panel/server.mjs": "panel/server.mjs",
      "../../../scripts/openclaw_codex_add_profile.mjs": "scripts/openclaw_codex_add_profile.mjs"
    }
  }
}
